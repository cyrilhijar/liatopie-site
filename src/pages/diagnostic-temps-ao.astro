---
import Layout from '../layouts/Layout.astro';
import data from '../content/diagnostic.json';

const { intro, resultat, merci } = data;
---

<Layout
  title="Diagnostic temps de réponse aux appels d'offres — Liatopie"
  description="Estimez votre potentiel de gain de temps sur vos réponses à appels d'offres en cinq questions."
  noindex={true}
>

<header class="diag-header">
  <div class="container diag-header-inner">
    <a href="/" class="logo-text" aria-label="Retour à l'accueil">LIATOPIE</a>
    <a href="/" class="back-link">Retour à l'accueil</a>
  </div>
</header>

<main class="diag-main">
  <div class="wrap">

    <!-- INTRO -->
    <div id="intro-step">
      <span class="eyebrow">{intro.eyebrow}</span>
      <h1>{intro.titre}</h1>
      <p class="lede">{intro.lede}</p>

      <div class="phases-card">
        <h3>{intro.phases_titre}</h3>
        {intro.phases.map(phase => (
          <div class="phase-row">
            <span class="phase-name">{phase.nom}</span>
            <span class="phase-time">{phase.temps}</span>
          </div>
        ))}
        <p class="source-note">{intro.source_note}</p>
      </div>

      <h2>{intro.questions_titre}</h2>

      {intro.questions.map((q, i) => (
        <div class="question-block" data-q={i + 1}>
          <div class="q-label">{q.label}</div>
          <div class="q-text" set:html={q.texte} />
          <div class="options">
            {q.options.map(opt => (
              <div class="opt" data-val={opt.val}>{opt.texte}</div>
            ))}
          </div>
        </div>
      ))}

      <div class="cta-row">
        <button class="btn-primary" id="submit-btn" disabled>{intro.cta}</button>
        <p class="progress-note" id="progress-note">0 sur {intro.questions.length} questions répondues</p>
      </div>
    </div>

    <!-- RESULT -->
    <div id="result" style="display:none">
      <div class="result-hero">
        <span class="eyebrow result-eyebrow">{resultat.eyebrow}</span>
        <h2 class="result-title">{resultat.titre}</h2>
        <div class="big-number" id="gain-hours">0 h</div>
        <p class="big-number-label">{resultat.gain_label} <span id="gain-pct">0 %</span> {resultat.gain_suffix}</p>
        <div class="stat-row">
          <div class="stat"><div class="val" id="stat-today">0 h</div><div class="lbl">{resultat.stat_avant_label}</div></div>
          <div class="stat"><div class="val" id="stat-after">0 h</div><div class="lbl">{resultat.stat_apres_label}</div></div>
        </div>
      </div>

      <div class="piliers-card">
        <p set:html={`<strong>${resultat.piliers_intro}</strong>`} />
        <div class="piliers-list">
          {resultat.piliers.map(p => <span class="pilier-tag">{p}</span>)}
        </div>
      </div>

      <div class="video-card">
        <p class="video-intro">{resultat.video_intro}</p>
        <div class="video-wrap">
          <iframe src="https://www.youtube.com/embed/NNTKxwXtk6A?si=-I7N0f_u-llmha0J" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </div>
      </div>

      <div class="lead-card">
        <h3>{resultat.lead_titre}</h3>
        <p class="lede2">{resultat.lead_lede}</p>
        <div class="two-col">
          <div class="field"><label for="prenom">Prénom</label><input type="text" id="prenom" /></div>
          <div class="field"><label for="nom">Nom</label><input type="text" id="nom" /></div>
        </div>
        <div class="field"><label for="entreprise">Entreprise</label><input type="text" id="entreprise" /></div>
        <div class="two-col">
          <div class="field"><label for="email">Email</label><input type="email" id="email" /></div>
          <div class="field"><label for="tel">Téléphone</label><input type="tel" id="tel" /></div>
        </div>
        <div class="cta-row" style="margin-top:18px">
          <button class="btn-primary" id="lead-submit">{resultat.lead_cta}</button>
        </div>
      </div>
    </div>

    <!-- THANK YOU -->
    <div id="thankyou" style="display:none; text-align:center; padding:40px 0">
      <span class="eyebrow" style="color:var(--slate)">{merci.eyebrow}</span>
      <h2>{merci.titre}</h2>
      <p class="lede">{merci.lede}</p>
    </div>

  </div>
</main>

<footer class="diag-footer">
  <div class="container">
    <p>© 2026 Liatopie · SARL Ecotopie ·
      <a href="/mentions-legales">Mentions légales</a> ·
      <a href="/politique-de-confidentialite">Politique de confidentialité</a>
    </p>
  </div>
</footer>

</Layout>

<style>
.diag-header { background: var(--petrole); padding: 0 var(--sp3); height: 68px; }
.diag-header-inner { display: flex; align-items: center; justify-content: space-between; height: 100%; }
.back-link { color: rgba(243,241,237,0.75); text-decoration: none; font-size: 0.9rem; transition: color var(--tr); }
.back-link:hover { color: var(--ivoire); }
.diag-main { background: var(--ivoire); min-height: 70vh; padding-bottom: 80px; }
.wrap { max-width: 760px; margin: 0 auto; padding: 48px 24px 0; }
.diag-footer { background: var(--graphite); padding: var(--sp3); text-align: center; }
.diag-footer p { font-size: 0.8125rem; color: rgba(243,241,237,0.5); margin: 0; }
.diag-footer a { color: rgba(243,241,237,0.7); text-decoration: none; }
.diag-footer a:hover { color: var(--ivoire); }

.eyebrow { display: inline-block; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--cuivre); font-weight: 600; margin-bottom: 10px; }
h1 { font-size: clamp(1.5rem, 3vw, 1.9rem); line-height: 1.25; margin-bottom: 12px; }
h2 { font-size: 1.3rem; margin-bottom: 16px; color: var(--petrole); }
.lede { font-size: 1.05rem; color: var(--graphite); opacity: 0.9; margin-bottom: 28px; }

.phases-card { background: #fff; border: 1px solid rgba(0,69,101,0.12); border-radius: 10px; padding: 24px 26px; margin-bottom: 36px; }
.phases-card h3 { font-size: 1rem; margin-bottom: 14px; }
.phase-row { display: flex; align-items: baseline; gap: 12px; padding: 9px 0; border-bottom: 1px solid rgba(0,69,101,0.07); font-size: 0.92rem; }
.phase-row:last-of-type { border-bottom: none; }
.phase-name { flex: 1; color: var(--graphite); }
.phase-time { color: var(--petrole); font-weight: 600; white-space: nowrap; }
.source-note { font-size: 0.78rem; color: var(--graphite); opacity: 0.65; margin-top: 14px; padding-top: 14px; border-top: 1px dashed rgba(0,69,101,0.15); margin-bottom: 0; }

.question-block { background: #fff; border: 1px solid rgba(0,69,101,0.12); border-radius: 10px; padding: 24px 26px; margin-bottom: 18px; }
.q-label { font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--slate); font-weight: 600; margin-bottom: 6px; }
.q-text { font-size: 1rem; margin-bottom: 16px; color: var(--graphite); }
.options { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
@media (max-width: 520px) { .options { grid-template-columns: 1fr; } }
.opt { border: 1.5px solid rgba(0,69,101,0.2); background: var(--ivoire); border-radius: 8px; padding: 12px 14px; font-size: 0.9rem; text-align: center; cursor: pointer; transition: all 0.15s ease; color: var(--graphite); user-select: none; }
.opt:hover { border-color: var(--petrole); }
.opt.selected { background: var(--petrole); border-color: var(--petrole); color: #fff; font-weight: 600; }

.cta-row { margin-top: 28px; text-align: center; }
.btn-primary { background: var(--cuivre); color: #fff; border: none; border-radius: 8px; padding: 15px 36px; font-size: 1rem; font-weight: 600; cursor: pointer; font-family: 'Sora', system-ui, sans-serif; transition: background 0.15s ease; }
.btn-primary:hover { background: #a35f24; }
.btn-primary:disabled { background: #c9b39e; cursor: not-allowed; }
.progress-note { font-size: 0.82rem; color: var(--graphite); opacity: 0.6; margin-top: 10px; margin-bottom: 0; }

.result-hero { background: var(--petrole); color: #fff; border-radius: 12px; padding: 34px 30px; text-align: center; margin-bottom: 28px; }
.result-eyebrow { color: var(--slate); }
.result-title { color: #fff; margin-bottom: 8px; }
.big-number { font-family: 'Sora', system-ui, sans-serif; font-size: 3rem; font-weight: 600; color: var(--cuivre); line-height: 1; margin: 10px 0; }
.big-number-label { font-size: 0.95rem; opacity: 0.9; margin-bottom: 0; }
.stat-row { display: flex; justify-content: center; gap: 36px; margin-top: 22px; flex-wrap: wrap; }
.stat { text-align: center; }
.stat .val { font-size: 1.4rem; font-weight: 600; font-family: 'Sora', system-ui, sans-serif; }
.stat .lbl { font-size: 0.78rem; opacity: 0.8; }

.piliers-card { background: #fff; border-left: 4px solid var(--slate); border-radius: 8px; padding: 22px 24px; margin-bottom: 28px; }
.piliers-card p { font-size: 0.95rem; margin-bottom: 14px; }
.piliers-list { display: flex; flex-wrap: wrap; gap: 8px; }
.pilier-tag { background: rgba(91,154,160,0.15); color: var(--petrole); font-size: 0.78rem; font-weight: 600; padding: 6px 12px; border-radius: 16px; }

.video-card { background: #fff; border-radius: 10px; overflow: hidden; margin-bottom: 28px; border: 1px solid rgba(0,69,101,0.12); }
.video-intro { padding: 18px 22px 0; font-size: 0.92rem; margin-bottom: 0; }
.video-wrap { position: relative; width: 100%; padding-top: 56.25%; margin-top: 14px; }
.video-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }

.lead-card { background: #fff; border: 1.5px solid var(--cuivre); border-radius: 10px; padding: 26px; }
.lead-card h3 { font-size: 1.05rem; margin-bottom: 6px; }
.lede2 { font-size: 0.9rem; opacity: 0.85; margin-bottom: 18px; }
.field { margin-bottom: 12px; }
.field label { display: block; font-size: 0.8rem; font-weight: 600; color: var(--petrole); margin-bottom: 5px; }
.field input { width: 100%; padding: 11px 13px; border: 1.5px solid rgba(0,69,101,0.2); border-radius: 7px; font-size: 0.92rem; font-family: inherit; background: var(--ivoire); }
.field input:focus { outline: none; border-color: var(--petrole); background: #fff; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
@media (max-width: 520px) { .two-col { grid-template-columns: 1fr; } }
</style>

<script is:inline>
  const WEBHOOK = 'https://hook.eu1.make.com/vfyd4pesv3cyh1ku7bhjf99gx3dc1cw2';
  const gainRates = { 1: 0.42, 2: 0.38, 3: 0.15, 4: 0.58, 5: 0.25 };
  const answers = {};

  document.querySelectorAll('.question-block').forEach(function(block) {
    const q = Number(block.dataset.q);
    block.querySelectorAll('.opt').forEach(function(opt) {
      opt.addEventListener('click', function() {
        block.querySelectorAll('.opt').forEach(function(o) { o.classList.remove('selected'); });
        opt.classList.add('selected');
        answers[q] = parseFloat(opt.dataset.val || '0');
        updateProgress();
      });
    });
  });

  function updateProgress() {
    const count = Object.keys(answers).length;
    const total = document.querySelectorAll('.question-block').length;
    const note = document.getElementById('progress-note');
    const btn = document.getElementById('submit-btn');
    if (note) note.textContent = count + ' sur ' + total + ' questions répondues';
    if (btn) btn.disabled = count < total;
  }

  const submitBtn = document.getElementById('submit-btn');
  if (submitBtn) submitBtn.addEventListener('click', function() {
    let totalToday = 0;
    let totalGain = 0;
    for (let q = 1; q <= 5; q++) {
      const t = answers[q] || 0;
      totalToday += t;
      totalGain += t * (gainRates[q] || 0);
    }
    const totalAfter = totalToday - totalGain;
    const pct = Math.round((totalGain / totalToday) * 100);
    function fmt(n) { return n.toFixed(1).replace('.', ',') + ' h'; }
    document.getElementById('gain-hours').textContent = fmt(totalGain);
    document.getElementById('gain-pct').textContent = pct + ' %';
    document.getElementById('stat-today').textContent = fmt(totalToday);
    document.getElementById('stat-after').textContent = fmt(totalAfter);
    window.__diagResult = { gain_hours: totalGain, gain_pct: pct };
    document.getElementById('intro-step').style.display = 'none';
    document.getElementById('result').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  const leadSubmit = document.getElementById('lead-submit');
  if (leadSubmit) leadSubmit.addEventListener('click', async function() {
    function get(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }
    const email = get('email');
    const nom = get('nom');
    if (!email || !nom) { alert('Merci de renseigner au moins votre nom et votre email.'); return; }
    const btn = document.getElementById('lead-submit');
    btn.disabled = true;
    btn.textContent = 'Envoi en cours...';
    const result = window.__diagResult || {};
    try {
      const res = await fetch(WEBHOOK, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ prenom: get('prenom'), nom: nom, entreprise: get('entreprise'), email: email, tel: get('tel'), gain_hours: result.gain_hours || 0, gain_pct: result.gain_pct || 0 }),
      });
      if (res.ok) {
        document.getElementById('result').style.display = 'none';
        document.getElementById('thankyou').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else { throw new Error('HTTP ' + res.status); }
    } catch(e) {
      alert('Une erreur est survenue. Merci de réessayer.');
      btn.disabled = false;
      btn.textContent = 'Recevoir mon analyse';
    }
  });
</script>
