---
import Layout from '../layouts/Layout.astro';
import cms from '../content/home.json';

const { hero, pourquoi, pour_qui, comment, preuve_sociale, contact } = cms;
const steps = comment.etapes;
---

<Layout>

  <!-- ═══ NAVIGATION ═══════════════════════════════════════════════════════ -->
  <header class="nav-header" id="top">
    <div class="container nav-inner">
      <a href="/#top" class="nav-logo" aria-label="Liatopie — accueil">
        <span class="logo-text">LIATOPIE</span>
      </a>

      <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu" aria-label="Ouvrir le menu">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav-menu" id="navMenu" role="navigation">
        <a href="/#approche">Notre approche</a>
        <a href="/#pour-qui">Pour qui</a>
        <a href="/#comment">Comment</a>
        <a href="/#contact" class="btn btn-primary nav-cta">Parlons de votre entreprise</a>
      </nav>
    </div>
  </header>


  <!-- ═══ HERO ══════════════════════════════════════════════════════════════ -->
  <section class="hero section--ivoire" aria-labelledby="hero-title">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1 id="hero-title">
          {hero.title}
        </h1>
        <p class="hero-subline">
          {hero.subtitle}
        </p>
        <div class="hero-actions">
          <a href="#contact" class="btn btn-primary">{hero.cta_primary}</a>
          <a href="#comment" class="btn-text">{hero.cta_secondary}</a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <svg viewBox="0 0 420 380" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero-svg">
          <!-- Fond -->
          <rect x="20" y="20" width="380" height="340" rx="16" fill="#EAE7E2"/>
          <!-- Ligne de cascade -->
          <line x1="210" y1="60" x2="210" y2="320" stroke="#5B9AA0" stroke-width="2" stroke-dasharray="6 4"/>
          <!-- Cercles étapes -->
          <circle cx="210" cy="75"  r="28" fill="#004565"/>
          <circle cx="210" cy="155" r="28" fill="#004565"/>
          <circle cx="210" cy="235" r="28" fill="#BE6E2A"/>
          <circle cx="210" cy="315" r="22" fill="#5B9AA0" opacity="0.7"/>
          <!-- Labels -->
          <rect x="250" y="60"  width="120" height="30" rx="6" fill="#004565" opacity="0.12"/>
          <rect x="250" y="140" width="100" height="30" rx="6" fill="#004565" opacity="0.12"/>
          <rect x="250" y="220" width="110" height="30" rx="6" fill="#BE6E2A" opacity="0.15"/>
          <rect x="250" y="300" width="90"  height="30" rx="6" fill="#5B9AA0" opacity="0.2"/>
          <!-- Chiffres -->
          <text x="210" y="80"  text-anchor="middle" fill="#F3F1ED" font-family="Sora, sans-serif" font-size="14" font-weight="600">01</text>
          <text x="210" y="160" text-anchor="middle" fill="#F3F1ED" font-family="Sora, sans-serif" font-size="14" font-weight="600">02</text>
          <text x="210" y="240" text-anchor="middle" fill="#F3F1ED" font-family="Sora, sans-serif" font-size="14" font-weight="600">03</text>
          <text x="210" y="320" text-anchor="middle" fill="#F3F1ED" font-family="Sora, sans-serif" font-size="11" font-weight="600">∞</text>
          <!-- Petit badge OPCO -->
          <rect x="40" y="60" width="70" height="24" rx="12" fill="#BE6E2A" opacity="0.9"/>
          <text x="75" y="76" text-anchor="middle" fill="#F3F1ED" font-family="Source Sans Pro, sans-serif" font-size="11">OPCO ✓</text>
        </svg>
      </div>
    </div>
  </section>


  <!-- ═══ POURQUOI LIATOPIE ════════════════════════════════════════════════ -->
  <section id="approche" class="section section--white" aria-labelledby="approche-title">
    <div class="container">
      <div class="section-header">
        <h2 id="approche-title">{pourquoi.title}</h2>
        <p class="section-intro">
          {pourquoi.intro}
        </p>
      </div>

      <div class="cards-grid">
        <article class="card">
          <div class="card-icon card-icon--petrole">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <h3>{pourquoi.cards[0].titre}</h3>
          <p>{pourquoi.cards[0].corps}</p>
        </article>

        <article class="card">
          <div class="card-icon card-icon--cuivre">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <h3>{pourquoi.cards[1].titre}</h3>
          <p>{pourquoi.cards[1].corps}</p>
        </article>

        <article class="card">
          <div class="card-icon card-icon--slate">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="32" height="32">
              <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
              <polyline points="17 6 23 6 23 12"/>
            </svg>
          </div>
          <h3>{pourquoi.cards[2].titre}</h3>
          <p>{pourquoi.cards[2].corps}</p>
          {pourquoi.cards[2].gain_phrase && (
            <p class="card-gain">{pourquoi.cards[2].gain_phrase}</p>
          )}
        </article>
      </div>
    </div>
  </section>


  <!-- ═══ POUR QUI ═════════════════════════════════════════════════════════ -->
  <section id="pour-qui" class="section section--ivoire" aria-labelledby="pourqui-title">
    <div class="container pourqui-inner">
      <div class="pourqui-text">
        <h2 id="pourqui-title">{pour_qui.titre}</h2>

        <p>{pour_qui.corps_1}</p>

        <p class="stat-line">
          <strong>{pour_qui.stat_texte}</strong>
          <cite>({pour_qui.stat_source})</cite>
        </p>

        <p>{pour_qui.corps_2} <cite>({pour_qui.corps_2_source})</cite></p>
      </div>

      <aside class="pourqui-encart">
        <blockquote>
          <p>{pour_qui.encart_quote}</p>
          <footer>
            <cite>{pour_qui.encart_source}</cite>
            <strong>{pour_qui.encart_cta}</strong>
          </footer>
        </blockquote>
      </aside>
    </div>
  </section>


  <!-- ═══ COMMENT ══════════════════════════════════════════════════════════ -->
  <section id="comment" class="section section--white" aria-labelledby="comment-title">
    <div class="container">
      <div class="section-header">
        <h2 id="comment-title">{comment.titre}</h2>
        <p class="section-intro">
          {comment.cascade_mecanisme}
        </p>
        <p class="section-intro section-intro--muted">
          {comment.intro}
        </p>
      </div>

      <ol class="steps-list">
        {steps.map((step) => (
          <li class="step">
            <div class="step-num">{step.num}</div>
            <div class="step-content">
              <div class="step-header">
                <h3 class="step-tag">{step.tag}</h3>
                <span class="step-detail">{step.detail}</span>
              </div>
              <p>{step.corps}</p>
              <p class="step-deliverable">{step.livrable}</p>
              {step.prix && (
                <p class="step-prix">{step.prix}</p>
              )}
            </div>
          </li>
        ))}
      </ol>

      <p class="opco-note">{contact.opco_info}</p>
    </div>
  </section>


  <!-- ═══ PREUVE SOCIALE ═══════════════════════════════════════════════════ -->
  <section class="section section--ivoire" aria-labelledby="preuve-title">
    <div class="container">
      <div class="section-header">
        <h2 id="preuve-title">{preuve_sociale.titre}</h2>
        <p class="section-intro">{preuve_sociale.sous_titre}</p>
      </div>

      <div class="verbatims-grid">
        {preuve_sociale.verbatims.map((v) => (
          <blockquote class="verbatim">
            <p>"{v}"</p>
          </blockquote>
        ))}
      </div>

      <p class="preuve-caution">{preuve_sociale.caution}</p>
    </div>
  </section>


  <!-- ═══ FORMULAIRE ═══════════════════════════════════════════════════════ -->
  <section id="contact" class="section section--white" aria-labelledby="contact-title">
    <div class="container contact-inner">
      <div class="contact-text">
        <h2 id="contact-title">{contact.titre}</h2>
        <p>{contact.sous_titre}</p>
        <ul class="contact-list">
          <li>{contact.item_1}</li>
          <li>{contact.item_2}</li>
        </ul>
      </div>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form"
        id="form-contact"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="honeypot-field" aria-hidden="true">
          <label>Ne pas remplir si vous êtes humain : <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="nom">Nom <span aria-hidden="true">*</span></label>
            <input class="form-input" type="text" id="nom" name="nom" required autocomplete="name" placeholder="Votre nom" />
          </div>
          <div class="form-group">
            <label class="form-label" for="email">Email <span aria-hidden="true">*</span></label>
            <input class="form-input" type="email" id="email" name="email" required autocomplete="email" placeholder="vous@entreprise.fr" />
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="telephone">Téléphone <span class="optional">(optionnel)</span></label>
          <input class="form-input" type="tel" id="telephone" name="telephone" autocomplete="tel" placeholder="+33 6 00 00 00 00" />
        </div>

        <div class="form-group">
          <label class="form-label" for="message">Où en êtes-vous avec l'IA dans votre entreprise ? <span aria-hidden="true">*</span></label>
          <textarea class="form-textarea" id="message" name="message" required rows="5" placeholder="Dites-nous en autant ou aussi peu que vous voulez."></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Envoyer</button>
      </form>
    </div>
  </section>


  <!-- ═══ FOOTER ════════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="logo-text">LIATOPIE</span>
        <p>On aide les PME à mettre l'IA au travail sans y perdre le contrôle, leurs données ni leur savoir-faire.</p>
      </div>

      <nav class="footer-nav" aria-label="Navigation secondaire">
        <a href="/#approche">Notre approche</a>
        <a href="/#pour-qui">Pour qui</a>
        <a href="/#comment">Comment</a>
        <a href="/#contact">Contact</a>
      </nav>

      <div class="footer-legal">
        <a href="/mentions-legales">Mentions légales</a>
        <a href="/politique-de-confidentialite">Politique de confidentialité</a>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <p>© 2026 Liatopie · SARL Ecotopie · Tous droits réservés</p>
      </div>
    </div>
  </footer>

</Layout>


<style>
/* ── Navigation ──────────────────────────────────────────────────────────── */
.nav-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--petrole);
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 68px;
  gap: var(--sp3);
}

.nav-logo { text-decoration: none; }

.logo-text {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--ivoire);
  letter-spacing: 0.08em;
}

.nav-menu {
  display: flex;
  align-items: center;
  gap: var(--sp3);
}

.nav-menu a {
  color: rgba(243,241,237,0.85);
  text-decoration: none;
  font-size: 0.9375rem;
  transition: color var(--tr);
}

.nav-menu a:hover { color: var(--ivoire); }

.nav-cta { color: var(--ivoire) !important; font-size: 0.875rem !important; padding: 8px 18px !important; }

.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
}

.nav-toggle span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--ivoire);
  border-radius: 2px;
  transition: all var(--tr);
}

/* ── Hero ────────────────────────────────────────────────────────────────── */
.hero { padding: var(--sp7) 0; }

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp6);
  align-items: center;
}

.hero-text { max-width: 560px; }

.hero-text h1 { margin-bottom: var(--sp3); }

.hero-subline {
  font-size: 1.125rem;
  color: var(--graphite);
  margin-bottom: var(--sp4);
  line-height: 1.6;
}

.hero-actions {
  display: flex;
  gap: var(--sp3);
  flex-wrap: wrap;
  align-items: center;
}

.btn-text {
  font-size: 0.9375rem;
  color: var(--petrole);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: rgba(0,69,101,0.4);
  transition: text-decoration-color var(--tr);
}

.btn-text:hover {
  text-decoration-color: var(--petrole);
}

.hero-visual {
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-svg {
  width: 100%;
  max-width: 420px;
  height: auto;
  border-radius: var(--r-lg);
}

/* ── Section headers ─────────────────────────────────────────────────────── */
.section-header { margin-bottom: var(--sp5); max-width: 700px; }
.section-header h2 { margin-bottom: var(--sp2); }
.section-intro { font-size: 1.0625rem; color: var(--graphite); margin-bottom: var(--sp2); }
.section-intro--muted { font-size: 0.9375rem; color: var(--slate); }

/* ── Cards grid ──────────────────────────────────────────────────────────── */
.cards-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp3);
}

.card-icon {
  width: 52px; height: 52px;
  border-radius: var(--r-md);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: var(--sp2);
}

.card-icon--petrole { background: rgba(0,69,101,0.1);  color: var(--petrole); }
.card-icon--cuivre  { background: rgba(190,110,42,0.1); color: var(--cuivre); }
.card-icon--slate   { background: rgba(91,154,160,0.15); color: var(--slate); }

.card h3 { margin-bottom: var(--sp1); }

.card-gain {
  margin-top: var(--sp2);
  font-size: 0.9375rem;
  color: var(--petrole);
  font-style: italic;
  line-height: 1.5;
}

/* ── Pour qui ────────────────────────────────────────────────────────────── */
.pourqui-inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--sp6);
  align-items: start;
}

.pourqui-text h2 { margin-bottom: var(--sp3); }
.pourqui-text p { margin-bottom: var(--sp3); }

.stat-line {
  border-left: 3px solid var(--cuivre);
  padding-left: var(--sp2);
  font-size: 1rem;
}

cite {
  display: block;
  font-style: normal;
  font-size: 0.8125rem;
  color: var(--slate);
  margin-top: 4px;
}

.pourqui-encart {
  position: sticky;
  top: 88px;
}

.pourqui-encart blockquote {
  background: var(--petrole);
  color: var(--ivoire);
  border-radius: var(--r-lg);
  padding: var(--sp3);
  font-style: normal;
}

.pourqui-encart blockquote p {
  font-size: 1.0625rem;
  line-height: 1.5;
  margin-bottom: var(--sp2);
  color: var(--ivoire);
}

.pourqui-encart blockquote footer {
  border-top: 1px solid rgba(243,241,237,0.2);
  padding-top: var(--sp2);
  display: flex;
  flex-direction: column;
  gap: var(--sp1);
}

.pourqui-encart blockquote footer cite {
  color: rgba(243,241,237,0.65);
  font-size: 0.8125rem;
}

.pourqui-encart blockquote footer strong {
  color: var(--ivoire);
  font-size: 0.9375rem;
}

/* ── Steps ───────────────────────────────────────────────────────────────── */
.steps-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
  max-width: 760px;
}

.steps-list::before {
  content: '';
  position: absolute;
  left: 28px;
  top: 56px;
  bottom: 56px;
  width: 2px;
  background: linear-gradient(to bottom, var(--petrole), var(--slate));
  opacity: 0.2;
}

.step {
  display: flex;
  gap: var(--sp3);
  padding: var(--sp3) 0;
  position: relative;
}

.step-num {
  flex-shrink: 0;
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--petrole);
  color: var(--ivoire);
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.step:last-child .step-num {
  background: var(--slate);
}

.step-content { padding-top: 8px; }

.step-header {
  display: flex;
  align-items: baseline;
  gap: var(--sp2);
  margin-bottom: var(--sp1);
  flex-wrap: wrap;
}

.step-tag {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--petrole);
  margin: 0;
}

.step-detail {
  font-size: 0.8125rem;
  color: var(--slate);
  background: rgba(91,154,160,0.1);
  padding: 2px 10px;
  border-radius: 20px;
  white-space: nowrap;
}

.step-deliverable {
  margin-top: var(--sp1);
  font-size: 0.875rem;
  color: var(--cuivre);
  font-weight: 600;
}

.step-prix {
  margin-top: 4px;
  font-size: 0.8125rem;
  color: var(--graphite);
  opacity: 0.75;
}

.opco-note {
  margin-top: var(--sp4);
  max-width: 680px;
  font-size: 0.9375rem;
  color: var(--slate);
  border-left: 3px solid var(--slate);
  padding-left: var(--sp2);
}

/* ── Preuve sociale ──────────────────────────────────────────────────────── */
.verbatims-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--sp3);
  margin-bottom: var(--sp4);
}

.verbatim {
  background: #fff;
  border-radius: var(--r-lg);
  padding: var(--sp3);
  box-shadow: var(--shadow);
  font-style: normal;
  border-left: 3px solid var(--slate);
}

.verbatim p {
  font-size: 1rem;
  color: var(--graphite);
  line-height: 1.55;
  margin: 0;
}

.preuve-caution {
  font-size: 0.875rem;
  color: var(--slate);
  max-width: 600px;
}

/* ── Contact ─────────────────────────────────────────────────────────────── */
.contact-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp6);
  align-items: start;
}

.contact-text h2 { margin-bottom: var(--sp2); }
.contact-text p { margin-bottom: var(--sp2); }

.contact-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--sp1);
}

.contact-list li::before {
  content: '→ ';
  color: var(--cuivre);
  font-weight: 600;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: var(--sp2);
  background: #fff;
  padding: var(--sp3);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow);
}

.honeypot-field {
  position: absolute;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  overflow: hidden;
  opacity: 0;
  pointer-events: none;
  tab-index: -1;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp2);
}

.form-group { display: flex; flex-direction: column; gap: 4px; }

.optional {
  font-weight: 400;
  color: var(--slate);
  font-size: 0.8125rem;
}

/* ── Footer ──────────────────────────────────────────────────────────────── */
.footer { background: var(--graphite); color: var(--ivoire); }

.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto auto;
  gap: var(--sp5);
  align-items: start;
  padding: var(--sp5) var(--sp3);
}

.footer-brand .logo-text { display: block; margin-bottom: var(--sp1); }
.footer-brand p { font-size: 0.875rem; color: rgba(243,241,237,0.65); max-width: 280px; }

.footer-nav, .footer-legal {
  display: flex;
  flex-direction: column;
  gap: var(--sp1);
}

.footer-nav a, .footer-legal a {
  color: rgba(243,241,237,0.75);
  text-decoration: none;
  font-size: 0.9rem;
  transition: color var(--tr);
}

.footer-nav a:hover, .footer-legal a:hover { color: var(--ivoire); }

.footer-bottom {
  border-top: 1px solid rgba(243,241,237,0.1);
  padding: var(--sp2) var(--sp3);
}

.footer-bottom p {
  font-size: 0.8125rem;
  color: rgba(243,241,237,0.45);
  margin: 0;
}

/* ── Responsive ──────────────────────────────────────────────────────────── */
@media (max-width: 1023px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-visual { display: none; }
